{
  "name": "hora",
  "version": "0.0.1",
  "type": "module",
  "description": "Hora Space desktop app",
  "author": "Hora",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "prepare:electron": "node scripts/prepare-electron.mjs",
    "prepare:release-assets": "node scripts/collect-release-assets.mjs",
    "dist": "npm run build && npm run prepare:electron && electron-builder && npm run prepare:release-assets",
    "dist:mac": "npm run build && npm run prepare:electron && electron-builder --mac && npm run prepare:release-assets",
    "dist:win": "node scripts/ensure-windows-host.mjs && npm run build && npm run prepare:electron && electron-builder --win && npm run prepare:release-assets",
    "dist:win:x64": "node scripts/ensure-windows-host.mjs && npm run build && npm run prepare:electron && electron-builder --win --x64 && npm run prepare:release-assets",
    "dist:win:arm64": "node scripts/ensure-windows-host.mjs && npm run build && npm run prepare:electron && electron-builder --win --arm64 && npm run prepare:release-assets",
    "electron:dev": "concurrently \"npm run dev\" \"cd electron && ELECTRON_RENDERER_URL=http://localhost:3000 npm run start\"",
    "electron:prod": "npm run build && concurrently \"npm run start\" \"npx wait-on http://localhost:3000 && cd electron && npm run start\""
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "@floating-ui/react": "^0.27.19",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-highlight": "^3.23.5",
    "@tiptap/extension-horizontal-rule": "^3.23.5",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-list": "^3.23.5",
    "@tiptap/extension-subscript": "^3.23.5",
    "@tiptap/extension-superscript": "^3.23.5",
    "@tiptap/extension-text-align": "^3.23.5",
    "@tiptap/extension-typography": "^3.23.5",
    "@tiptap/extensions": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.8.0",
    "markdown-it": "^14.1.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "^5.3.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/lodash.throttle": "^4.1.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^10.0.3",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "electronVersion": "37.0.0",
    "appId": "com.hora.space",
    "productName": "Hora Space",
    "asar": true,
    "afterPack": "scripts/electron-after-pack.cjs",
    "directories": {
      "output": "dist-electron/releases"
    },
    "artifactName": "HoraSpace-${version}-${arch}.${ext}",
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/db.cjs",
      "electron/space.cjs",
      "electron/resources/**/*",
      "electron/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": "icon",
        "to": "icon"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "icon": "icon/hora_space_icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "icon/hora_space_icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "icon/hora_space_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
